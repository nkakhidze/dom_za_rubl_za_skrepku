# PostgreSQL connection parts used by app.core.config.Settings.database_url
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=paperclip_house

# SQLAlchemy engine echo
DB_ECHO=false

# Backend logging
LOG_DIR=logs
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=4
LOG_TO_CONSOLE=false

# Public URLs and uploads
PUBLIC_BASE_URL=https://tomsk-dom-za-skrepku.space
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=15
IMAGE_MAX_FILE_SIZE_MB=15
IMAGE_MAX_DIMENSION=10000
IMAGE_MAIN_MAX_SIZE=1920
IMAGE_MAIN_QUALITY=82
IMAGE_THUMB_MAX_SIZE=640
IMAGE_THUMB_QUALITY=78
IMAGE_WEBP_METHOD=4

# Admin API
ADMIN_API_TOKEN=change_me
ALLOW_ADMIN_TOKEN_AUTH=true
ALLOW_ADMIN_TOKEN_FALLBACK=true
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEV_MODE=false
INITIAL_ADMIN_LOGIN=admin
INITIAL_ADMIN_PASSWORD=change_me

# Telegram bot and backend notifications
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_BOT_USERNAME=change_me_bot
TELEGRAM_INTERNAL_API_TOKEN=change_me
BACKEND_API_URL=https://tomsk-dom-za-skrepku.space
BACKEND_BASE_URL=https://tomsk-dom-za-skrepku.space
PUBLIC_SITE_URL=https://tomsk-dom-za-skrepku.space

# CORS for frontend dev server
CORS_ORIGINS=["https://tomsk-dom-za-skrepku.space","http://127.0.0.1:3000","http://localhost:3000","http://127.0.0.1:5173","http://localhost:5173"]

# Frontend example value. Vite reads this from frontend/.env, not backend .env.
VITE_API_BASE_URL=https://tomsk-dom-za-skrepku.space
